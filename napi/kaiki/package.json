{
  "name": "@kaiki/diff",
  "version": "0.0.1",
  "description": "Node.js bindings for kaiki visual regression testing",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./plugin-loader": {
      "types": "./plugin-loader.d.ts",
      "import": "./plugin-loader.js",
      "require": "./plugin-loader.js"
    }
  },
  "napi": {
    "binaryName": "kaiki-diff",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-unknown-linux-musl",
      "aarch64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/kaiki"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "plugin-loader.js",
    "plugin-loader.d.ts"
  ],
  "devDependencies": {
    "@napi-rs/cli": "3.5.1",
    "@types/node": "25.3.5",
    "@types/pngjs": "6.0.5",
    "pngjs": "7.0.0",
    "typescript": "^5",
    "vitest": "4.0.18"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release && tsc plugin-loader.ts --declaration --esModuleInterop --module commonjs --target es2020 --moduleResolution node --skipLibCheck",
    "build:debug": "napi build --platform && tsc plugin-loader.ts --declaration --esModuleInterop --module commonjs --target es2020 --moduleResolution node --skipLibCheck",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
